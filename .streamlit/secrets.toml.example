# Copiar este archivo a secrets.toml y completar. NO subir secrets.toml a Git.

[connections.supabase]
SUPABASE_URL = "https://TU-PROYECTO.supabase.co"
SUPABASE_KEY = "pega_aqui_la_clave_service_role"

# Opcional: firma de la cookie de sesión (si no pones nada, se deriva de SUPABASE_KEY).
# [auth]
# SESSION_SIGNING_KEY = "cadena_larga_aleatoria_solo_servidor"

# Fotos en Storage (subida, galería, portada). El catálogo HTML en Reportes SIGUE aunque esto esté en false.
# [catalogo]
# bucket = "movi-productos"
# storage_fotos = false
# enabled = false   # mismo efecto que storage_fotos = false (nombre viejo)

# Respaldo automático diario (solo superusuario al abrir la app): JSON compacto + gzip.
# Ejecutá en Supabase: supabase/patch_010_erp_kv.sql (tabla erp_kv).
# En Streamlit Cloud, opcional: bucket privado + política para service_role y nombre abajo.
# [auto_backup]
# enabled = true
# retain_days = 14
# storage_bucket = ""
